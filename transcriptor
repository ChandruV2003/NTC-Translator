#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PYTHON_BIN="$ROOT_DIR/.venv/bin/python"

if [[ ! -x "$PYTHON_BIN" ]]; then
  printf 'Transcriptor is not installed yet.\nRun this first:\n  ./install.sh\n' >&2
  exit 1
fi

exec "$PYTHON_BIN" -m transcriptor_app "$@"
